{
  "expo": {
    "name": "Žiju Life",
    "slug": "ziju-life",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "zijulife",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDFDF7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "life.ziju.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FDFDF7",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "life.ziju.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "ZijuWidget",
              "displayName": "Žiju Life",
              "description": "Rituály a úkoly na dnešek",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "systemLarge"
              ],
              "contentMarginsDisabled": false
            }
          ]
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "ZijuSmallRitual",
              "label": "Žiju - Rituály",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "description": "Další rituál",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "ZijuSmallTodo",
              "label": "Žiju - To-Do",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "description": "Další úkol",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "ZijuMedium",
              "label": "Žiju Life",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "description": "Rituál a úkol",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "ZijuLarge",
              "label": "Žiju Life - vše",
              "minWidth": "250dp",
              "minHeight": "250dp",
              "targetCellWidth": 4,
              "targetCellHeight": 4,
              "resizeMode": "vertical",
              "description": "Všechny rituály a úkoly",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6cc7445a-ddca-42fe-9c79-0afbe2bb71e4"
      }
    },
    "owner": "ziju-life"
  }
}
