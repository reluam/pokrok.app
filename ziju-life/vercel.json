{
  "crons": [
    {"path": "/api/cron/send-newsletters", "schedule": "33 11 * * *"},
    {"path": "/api/cron/daily-brief", "schedule": "0 5 * * *"}
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), display-capture=(), fullscreen=()"
        }
      ]
    }
  ]
}
